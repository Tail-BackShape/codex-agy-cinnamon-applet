{
  "layout": {
    "type": "layout",
    "pages": ["general"],
    "general": {
      "type": "page",
      "title": "General",
      "sections": ["providers", "refresh", "display"]
    },
    "providers": {
      "type": "section",
      "title": "Providers",
      "keys": ["command-path", "enable-codex", "enable-antigravity"]
    },
    "refresh": {
      "type": "section",
      "title": "Refresh",
      "keys": ["refresh-interval"]
    },
    "display": {
      "type": "section",
      "title": "Display",
      "keys": ["display-mode"]
    }
  },
  "command-path": {
    "type": "entry",
    "default": "codexbar",
    "description": "CodexBar command path"
  },
  "enable-codex": {
    "type": "switch",
    "default": true,
    "description": "Show Codex"
  },
  "enable-antigravity": {
    "type": "switch",
    "default": true,
    "description": "Show Antigravity"
  },
  "refresh-interval": {
    "type": "spinbutton",
    "default": 60,
    "min": 30,
    "max": 3600,
    "step": 30,
    "units": "seconds",
    "description": "Refresh interval"
  },
  "display-mode": {
    "type": "combobox",
    "default": "used",
    "description": "Displayed percentage",
    "options": {
      "Used": "used",
      "Remaining": "remaining"
    }
  }
}
